# Cloud AI: openrouter | together | huggingface | arcee | groq | grok | xai | nvidia  (USE_OLLAMA=true overrides all cloud).
AI_PROVIDER=openrouter

# Hugging Face Inference (when AI_PROVIDER=huggingface or hf) — OpenAI-compatible router
# https://huggingface.co/docs/api-inference/en/quicktour
# REQUIRED: Fine-grained token with "Inference: Make calls to Inference Providers" (NOT a classic read token).
# Create: https://huggingface.co/settings/tokens/new?ownUserPermissions=inference.serverless.write&tokenType=fineGrained
# Gated Llama: open model page → agree to license before API works.
# HF_TOKEN=
# HF_MODEL=meta-llama/Llama-4-Scout-17B-16E-Instruct
# (non-instruct weights: meta-llama/Llama-4-Scout-17B-16E)
# HF_BASE_URL=https://router.huggingface.co/v1

# Together AI (when AI_PROVIDER=together) — https://docs.together.ai/docs/openai-api-compatibility
# TOGETHER_API_KEY=
# TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
# TOGETHER_BASE_URL=https://api.together.xyz/v1

# Arcee AI direct API (when AI_PROVIDER=arcee) — https://docs.arcee.ai/api-reference
# Get keys: https://chat.arcee.ai → API keys. OpenAI-compatible; not the same as OpenRouter.
# ARCEE_API_KEY=
# ARCEE_MODEL=trinity-mini
# ARCEE_BASE_URL=https://api.arcee.ai/api/v1

# OpenRouter (when AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Groq (when AI_PROVIDER=groq) — https://console.groq.com/ → API Keys (gsk_...)
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# Free/on_demand tier: tight TPM — we trim OCR in the system prompt; 429 = one quick retry then fail fast.
# GROQ_CONTEXT_VISIBLE_MAX=900
# GROQ_429_MAX_ATTEMPTS=2
# GROQ_429_MAX_SLEEP_SEC=10
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# xAI Grok (when AI_PROVIDER=grok or xai) — https://console.x.ai/ → API keys (xai-...)
# XAI_API_KEY=
# (alias: GROK_API_KEY= for xAI only — confusing name; prefer XAI_API_KEY)
# XAI_MODEL=grok-4-1-fast-non-reasoning
# XAI_BASE_URL=https://api.x.ai/v1

# NVIDIA NIM (when AI_PROVIDER=nvidia or nvapi) — OpenAI-compatible; https://build.nvidia.com/explore
# Key from model page → Get API Key (nvapi-...). Alias: NVAPI_KEY=
# NVIDIA_API_KEY=
# NVIDIA_MODEL=meta/llama-3.1-8b-instruct
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional: use Ollama instead of cloud (set to true to use local Ollama)
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Max visible text length from screen OCR (chars)
SCREEN_TEXT_MAX_LENGTH=2000

# Width of the SideAI panel on the right (in pixels), used to exclude it from OCR
SIDEAI_PANEL_WIDTH=320

# Default number of web results for /api/search and /api/synthesize
DEFAULT_WEB_SEARCH_LIMIT=3

# Clipboard monitor toggle for renderer hints
CLIPBOARD_MONITOR_ENABLED=true

# RAG settings
RAG_CHUNK_SIZE=700
RAG_TOP_K=4

# Optional: require X-SideAI-Key on API routes (except /health, /docs). Use on shared machines.
# If set, add the same value to frontend env as VITE_SIDEAI_API_KEY (e.g. frontend/.env.local).
# SIDEAI_API_KEY=

# Clerk auth (Phase 2) — get from https://dashboard.clerk.com → API Keys
# Required for JWT verification on cloud-synced endpoints.
# CLERK_SECRET_KEY=sk_test_...
# CLERK_JWKS_URL=https://api.clerk.com/v1/jwks

# Managed AI tier — injected by Electron at build time, never commit real keys here.
# SIDEAI_MANAGED_GROQ_KEY=
# SIDEAI_MANAGED_HF_TOKEN=
# SIDEAI_MANAGED_DAILY_LIMIT=50

# Advanced integrations (disabled by default)
ENABLE_BROWSER_BRIDGE=false
ENABLE_VSCODE_BRIDGE=false
ENABLE_MACROS=false
ENABLE_TEAM_COLLAB=false

# Slack integration
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=

# GitHub integration
GITHUB_TOKEN=
GITHUB_API_BASE=https://api.github.com

# Calendar integration
CALENDAR_TOKEN=
CALENDAR_API_BASE=https://www.googleapis.com/calendar/v3
CALENDAR_ID=primary
CALENDAR_CLIENT_ID=
CALENDAR_CLIENT_SECRET=
CALENDAR_REDIRECT_URI=http://127.0.0.1:8000/api/integrations/calendar/oauth/callback
CALENDAR_AUTH_URI=https://accounts.google.com/o/oauth2/v2/auth
CALENDAR_TOKEN_URI=https://oauth2.googleapis.com/token

# Analytics + plugins
ANALYTICS_RETENTION_DAYS=30
PLUGINS_DIR=plugins

# Writeback integrations (optional) — used by POST /api/integrations/*
# Notion: Internal Integration token with write access to target page
# NOTION_INTEGRATION_TOKEN=
# (alias) NOTION_TOKEN=
# Obsidian: absolute path to vault root; appends markdown files
# OBSIDIAN_VAULT_PATH=
# Linear: API key + default team for new issues
# LINEAR_API_KEY=
# LINEAR_TEAM_ID=
# Jira Cloud: email + API token + project
# JIRA_HOST=your-domain.atlassian.net
# JIRA_EMAIL=
# JIRA_API_TOKEN=
# JIRA_PROJECT_KEY=
# JIRA_ISSUE_TYPE=Task
